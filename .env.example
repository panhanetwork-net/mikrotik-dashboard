# ─── MikroTik RouterOS API Credentials (NOC) ────────────────────────────────
MIKROTIK_USER=your_noc_username
MIKROTIK_PASS=your_noc_password

# ─── Telegram Alerting (Optional) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Technitium DNS Server Integration (Optional, for DNS monitoring) ────────
TECHNITIUM_URL=http://157.66.36.252:5380
TECHNITIUM_TOKEN=your_dns_api_token_here

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_SECRET=your-strong-random-secret-here

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Health Check Interval (ms) ──────────────────────────────────────────────
HEALTH_CHECK_INTERVAL=30000
